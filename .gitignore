# use custom ignores with this command:
# GIT_WORK_TREE=$HOME GIT_DIR=$HOME/.dotfiles.git git config --local core.excludesfile .gitignore.dotfiles

# Ignore everything by default.

*

# Add back items as needed.

# home (stow target root)
!home/

# config
!home/.config/
!home/.config/*

# antibody
!home/.config/antibody/
!home/.config/antibody/**

# atuin
!home/.config/atuin/
!home/.config/atuin/**

# bat
!home/.config/bat/
!home/.config/bat/**

# bin
!home/bin/
!home/bin/**
**/bin/gam7/
**/bin/gamadv-xtd3/

# bash
!home/.bash_profile
!home/.bashrc
!home/.config/bash/
!home/.config/bash/**
home/.config/bash/*.log

# blesh
!home/.config/blesh/
!home/.config/blesh/**

# docs
!docs/
!docs/**

# doom
!home/.config/doom/
!home/.config/doom/**

# editorconfig
!home/.editorconfig

# fish
!home/.config/fish/
!home/.config/fish/*
!home/.config/fish/**
home/.config/fish/fish_variables

# ghostty
!home/.config/ghostty/
!home/.config/ghostty/**

# git
!.gitignore
!home/.config/git/
!home/.config/git/**

# hammerspoon
!home/.hammerspoon/
!home/.hammerspoon/**/
!home/.hammerspoon/Spoons/**
!home/.hammerspoon/init.lua
!home/.hammerspoon/readme.md

# helix
!home/.config/helix/
!home/.config/helix/**

# homebrew
!home/.config/homebrew/
!home/.config/homebrew/**
home/.config/homebrew/trust.json.lock

# iterm2
!home/.config/iterm2/
!home/.config/iterm2/*.json

# kak
!home/.config/kak/
!home/.config/kak/**

# npm
!home/.config/npm/
!home/.config/npm/**

# neovim
!home/.config/nvim/
!home/.config/nvim/**

# readline
!home/.config/readline/
!home/.config/readline/**

# ripgrep
!home/.config/ripgrep/
!home/.config/ripgrep/**

# shell
!home/.config/shell/
!home/.config/shell/**

# starship
!home/.config/starship/
!home/.config/starship/**

# stow
!home/.stow-*

# tmux
!home/.config/tmux/
!home/.config/tmux/**

# vim
!home/.vimrc
!home/.config/vim/
!home/.config/vim/*.vim

# wezterm
!home/.config/wezterm/
!home/.config/wezterm/**

# wget
!home/.config/wget/
!home/.config/wget/**

# zed (settings only - prompts/ is a local LMDB database, not config)
!home/.config/zed/
!home/.config/zed/settings.json

# re-ignore local files
*.local
local.*
*.local/
*.local.*
!.local/
!.local/**

# helpers
!justfile
!LICENSE
!README.md

# final
*_history*
.DS_Store
