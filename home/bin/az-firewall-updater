#!/usr/bin/env bash

# Setup:
# az ad sp create-for-rbac --name "az-firewall-updater" --role Contributor \
#   --scopes /subscriptions/<sub-id>/resourceGroups/<rg> > "${XDG_DATA_HOME:-$HOME/.local/share}/secrets/work/azure/az-firewall-updater.jsonc"
SECRETS_FILE="${XDG_DATA_HOME:-$HOME/.local/share}/secrets/work/azure/az-firewall-updater.jsonc"

# secrets file format:
# {
#   "subscriptionId": "?",
#   "appId": "?",
#   "displayName": "?",
#   "password": "?",
#   "tenant": "?",
#   "rules": [
#     {
#       "type": "sqlserver",
#       "ruleName": "?",
#       "resourceGroup": "?",
#       "serverName": "?"
#     },
#     {
#       "type": "postgres",
#       "ruleName": "?",
#       "resourceGroup": "?",
#       "serverName": "?"
#     },
#     {
#       "type": "nsg",
#       "ruleName": "?",
#       "resourceGroup": "?",
#       "nsgName": "?"
#     }
#   ]
# }
# Add "skip": true to any rule to skip it without removing it.

jqc() {
  local file
  file="${*: -1}"
  sed 's|//.*||g; s|/\*.*\*\/||g' "$file" | jq -r "${*:1:$#-1}"
}

AZURE_CLIENT_ID=$(jqc '.appId' "$SECRETS_FILE")
AZURE_CLIENT_SECRET=$(jqc '.password' "$SECRETS_FILE")
AZURE_TENANT_ID=$(jqc '.tenant' "$SECRETS_FILE")
MY_IP=$(curl -s https://api.ipify.org)

az login --service-principal \
  --username "$AZURE_CLIENT_ID" \
  --password "$AZURE_CLIENT_SECRET" \
  --tenant "$AZURE_TENANT_ID" \
  --output none || { echo "Azure login failed"; exit 1; }

jqc '.rules[]' "$SECRETS_FILE" | jq -rc '.' | while IFS= read -r rule; do
  AZURE_RULE_TYPE=$(echo "$rule" | jq -r '.type // "sqlserver"')
  AZURE_RULE_NAME=$(echo "$rule" | jq -r '.ruleName')
  AZURE_RESOURCE_GROUP=$(echo "$rule" | jq -r '.resourceGroup')
  SKIP=$(echo "$rule" | jq -r '.skip // false')

  if [[ "$SKIP" == "true" ]]; then
    echo "Skipping $AZURE_RULE_TYPE rule $AZURE_RULE_NAME"
    continue
  fi

  if [[ "$AZURE_RULE_TYPE" == "nsg" ]]; then
    AZURE_NSG_NAME=$(echo "$rule" | jq -r '.nsgName')
    CURRENT_IP=$(az network nsg rule show \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --nsg-name "$AZURE_NSG_NAME" \
      --name "$AZURE_RULE_NAME" \
      --query sourceAddressPrefix -o tsv 2>/dev/null || echo "")
    if [[ "$CURRENT_IP" == "$MY_IP" ]]; then
      echo "NSG $AZURE_NSG_NAME rule $AZURE_RULE_NAME already set to $MY_IP, skipping"
      continue
    fi
    echo "Updating NSG $AZURE_NSG_NAME rule $AZURE_RULE_NAME to $MY_IP..."
    az network nsg rule update \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --nsg-name "$AZURE_NSG_NAME" \
      --name "$AZURE_RULE_NAME" \
      --source-address-prefix "$MY_IP" \
      --output none

  elif [[ "$AZURE_RULE_TYPE" == "postgres" ]]; then
    AZURE_SERVER_NAME=$(echo "$rule" | jq -r '.serverName')
    CURRENT_IP=$(az postgres flexible-server firewall-rule show \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --server-name "$AZURE_SERVER_NAME" \
      --name "$AZURE_RULE_NAME" \
      --query startIpAddress -o tsv 2>/dev/null || echo "")
    if [[ "$CURRENT_IP" == "$MY_IP" ]]; then
      echo "Postgres $AZURE_SERVER_NAME rule $AZURE_RULE_NAME already set to $MY_IP, skipping"
      continue
    fi
    echo "Updating Postgres $AZURE_SERVER_NAME firewall rule to $MY_IP..."
    az postgres flexible-server firewall-rule update \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --server-name "$AZURE_SERVER_NAME" \
      --name "$AZURE_RULE_NAME" \
      --start-ip-address "$MY_IP" \
      --end-ip-address "$MY_IP" \
      --output none

  else
    AZURE_SERVER_NAME=$(echo "$rule" | jq -r '.serverName')
    CURRENT_IP=$(az sql server firewall-rule show \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --server "$AZURE_SERVER_NAME" \
      --name "$AZURE_RULE_NAME" \
      --query startIpAddress -o tsv 2>/dev/null || echo "")
    if [[ "$CURRENT_IP" == "$MY_IP" ]]; then
      echo "SQL $AZURE_SERVER_NAME rule $AZURE_RULE_NAME already set to $MY_IP, skipping"
      continue
    fi
    echo "Updating SQL $AZURE_SERVER_NAME firewall rule to $MY_IP..."
    az sql server firewall-rule update \
      --resource-group "$AZURE_RESOURCE_GROUP" \
      --server "$AZURE_SERVER_NAME" \
      --name "$AZURE_RULE_NAME" \
      --start-ip-address "$MY_IP" \
      --end-ip-address "$MY_IP" \
      --output none
  fi
done
